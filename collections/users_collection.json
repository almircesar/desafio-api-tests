      "name": "[AUTH] Fluxos Positivos",
      "item": [
        {
          "name": "[AUTH] Realizar login válido",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const response = pm.response.json();",
                  "",
                  "pm.test(\"Status code deve ser 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Resposta deve conter mensagem de sucesso\", function () {",
                  "    pm.expect(response.message).to.eql(\"Login realizado com sucesso\");",
                  "});",
                  "",
                  "pm.test(\"Resposta deve conter token de autenticação\", function () {",
                  "    pm.expect(response.authorization).to.be.a(\"string\");",
                  "    pm.expect(response.authorization).to.include(\"Bearer\");",
                  "});",
                  "",
                  "pm.environment.set(\"token\", response.authorization);"
                ],
                "type": "text/javascript",
                "packages": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"fulano@qa.com\",\n  \"password\": \"teste\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "login"
              ]
            }
          },
          "response": []
        }
      ]
    },
